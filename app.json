{
  "expo": {
    "name": "fluidbody",
    "slug": "fluidbody",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ytissot.fluidbody",
      "buildNumber": "9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSHealthShareUsageDescription": "FluidBody utilise HealthKit pour enregistrer vos séances et remplir vos anneaux Fitness.",
        "NSHealthUpdateUsageDescription": "FluidBody enregistre vos séances de Pilates comme exercices dans Santé."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ytissot.fluidbody"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c94beda1-885e-48cd-83ca-2a1e2f10da79"
      }
    },
    "plugins": [
      "expo-localization",
      "react-native-health"
    ]
  }
}
